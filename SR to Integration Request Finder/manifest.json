{
  "name": "SR Search in Integration Requests",
  "description": "Right-click on Service Request number to search for its Integration Request. Auto-formats JSON and validates fields in INT-REQ pages.",
  "version": "1.2",
  "manifest_version": 3,
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.salesforce.com/*",
        "https://*.force.com/*",
        "https://*.lightning.force.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://*.salesforce.com/*",
        "https://*.force.com/*",
        "https://*.lightning.force.com/*"
      ],
      "js": ["content-json-formatter.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "permissions": ["contextMenus", "activeTab", "scripting", "tabs"],
  "action": {
    "default_title": "SR Search Integration Requests",
    "default_icon": {
      "16": "/images/311Logo_16.png",
      "32": "/images/311Logo_32.png",
      "48": "/images/311Logo_48.png",
      "128": "/images/311Logo_128.png"
    }
  },
  "icons": {
    "16": "/images/311Logo_16.png",
    "32": "/images/311Logo_32.png",
    "48": "/images/311Logo_48.png",
    "128": "/images/311Logo_128.png"
  }
}
