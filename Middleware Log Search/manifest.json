{
  "name": "SR  Search in Middleware Log",
  "description": "Right-click on Service Request number to search middleware logs in Kibana",
  "version": "1.0",
  "manifest_version": 3,
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.salesforce.com/*",
        "https://*.force.com/*",
        "https://*.lightning.force.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["jaeger-expand.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "*://portal.cc.toronto.ca/*",
        "*://staging.cc.toronto.ca/*"
      ],
      "js": ["error-trace-click.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "permissions": ["contextMenus", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Middleware Log Search",
    "default_icon": {
      "16": "/images/311Logo_16.png",
      "32": "/images/311Logo_32.png",
      "48": "/images/311Logo_48.png",
      "128": "/images/311Logo_128.png"
    }
  },
  "icons": {
    "16": "/images/311Logo_16.png",
    "32": "/images/311Logo_32.png",
    "48": "/images/311Logo_48.png",
    "128": "/images/311Logo_128.png"
  }
}
